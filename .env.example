# VITE_API_URL: base URL của NestJS backend thật (auth, sites, translate...).
# - Local thuần:  http://localhost:3001/api/v1
# - Qua ngrok:    https://<ngrok-id>.ngrok-free.app/api/v1 (khi backend được tunnel)
# Bắt buộc prefix VITE_ để Vite expose ra client bundle.
VITE_API_URL="http://localhost:3001/api/v1"
